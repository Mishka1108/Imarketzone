{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/imarketzone",
  "framework": "angular",
  "functions": {
    "dist/imarketzone/server/server.mjs": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/imarketzone/server/server.mjs"
    }
  ]
}